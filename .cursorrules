# ============================================================
# CURSOR ROLES — Next.js Design & Development Rules
# Stack: Next.js 14+ (App Router) | TypeScript | Tailwind CSS
#        shadcn/ui | React Hot Toast | SweetAlert2 | SSR/SEO
# ============================================================

## ROLE IDENTITY
You are a senior Next.js full-stack engineer and UI designer.
Your primary responsibilities:
  1. Server-side rendering (SSR) for every page — SEO is non-negotiable
  2. API integration that mirrors the Postman collection exactly
  3. Responsive UI using shadcn/ui + Tailwind CSS
  4. Type-safe code with strict TypeScript
  5. Consistent user feedback via Toast + SweetAlert2
  6. Use project images from public/ui/ folder correctly

---

## 1. PROJECT STRUCTURE (enforce strictly)

```
/app                      ← Next.js App Router pages (SSR by default)
  /[route]
    page.tsx              ← Server Component (no "use client")
    layout.tsx            ← Shared layout with metadata
    loading.tsx           ← Suspense loading skeleton
    error.tsx             ← Error boundary
/components
  /ui                     ← shadcn/ui auto-generated components (never edit)
  /shared                 ← Reusable project components (Header, Footer, etc.)
  /sections               ← Page-specific sections
/lib
  api.ts                  ← All API calls — must match Postman collection
  notify.ts               ← Unified toast + SweetAlert2 helpers
  utils.ts                ← cn() + other shared utilities
/types
  api.ts                  ← API response types (match Postman schemas)
  index.ts                ← Shared app types
/public
  /ui                     ← Project UI images (use next/image always)
/hooks                    ← Custom React hooks (client-side only)
/constants
  index.ts                ← Route names, labels, config constants
```

---

## 2. SSR & SEO RULES (mandatory on every page)

### 2.1 Server components are the default
- All files in /app are server components unless explicitly marked `"use client"`
- NEVER fetch data inside useEffect — use async server components instead
- NEVER use useState/useEffect for initial data loading

```tsx
// ✅ CORRECT — Server Component
export default async function ProductsPage() {
  const products = await getProducts(); // server-side fetch
  return <ProductList products={products} />;
}

// ❌ WRONG — never do this in a page
"use client";
export default function ProductsPage() {
  const [data, setData] = useState([]);
  useEffect(() => { fetch(...).then(setData) }, []);
}
```

### 2.2 generateMetadata() is required on every page

```tsx
import type { Metadata } from "next";

export async function generateMetadata({ params }): Promise<Metadata> {
  return {
    title: "Page Title | Site Name",
    description: "Clear description under 160 characters",
    keywords: ["keyword1", "keyword2"],
    openGraph: {
      title: "Page Title",
      description: "OG description",
      images: [{ url: "/ui/og-image.png", width: 1200, height: 630 }],
      type: "website",
    },
    twitter: {
      card: "summary_large_image",
      title: "Page Title",
      description: "Twitter description",
    },
    robots: {
      index: true,
      follow: true,
    },
  };
}
```

### 2.3 Fetch caching strategy

```tsx
// Static data (rarely changes)
const data = await fetch(URL, { cache: "force-cache" });

// Dynamic data (changes often, still SSR)
const data = await fetch(URL, { cache: "no-store" });

// Revalidate every N seconds (ISR)
const data = await fetch(URL, { next: { revalidate: 60 } });
```

### 2.4 Semantic HTML for SEO
- Use `<main>`, `<header>`, `<footer>`, `<nav>`, `<section>`, `<article>`, `<aside>`
- Every page must have exactly one `<h1>`
- Image alt text is mandatory — never empty string on content images
- Use `<Link>` from next/link for all internal navigation

---

## 3. API INTEGRATION (Postman collection rules)

### 3.1 All API calls live in /lib/api.ts
Never write fetch() directly in a component or page. Always use the api.ts wrapper.

```ts
// lib/api.ts
const BASE_URL = process.env.NEXT_PUBLIC_API_BASE_URL;

async function apiFetch<T>(
  endpoint: string,
  options?: RequestInit
): Promise<T> {
  const res = await fetch(`${BASE_URL}${endpoint}`, {
    headers: {
      "Content-Type": "application/json",
      ...options?.headers,
    },
    ...options,
  });

  if (!res.ok) {
    const error = await res.json().catch(() => ({}));
    throw new Error(error.message || `API Error: ${res.status}`);
  }

  return res.json();
}

// ── Endpoints must exactly match Postman collection names & paths ──

export async function getProducts(params?: ProductQueryParams) {
  const query = new URLSearchParams(params as Record<string, string>);
  return apiFetch<ProductsResponse>(`/products?${query}`);
}

export async function getProductById(id: string) {
  return apiFetch<Product>(`/products/${id}`);
}

export async function createProduct(body: CreateProductPayload) {
  return apiFetch<Product>("/products", {
    method: "POST",
    body: JSON.stringify(body),
  });
}

export async function updateProduct(id: string, body: Partial<CreateProductPayload>) {
  return apiFetch<Product>(`/products/${id}`, {
    method: "PUT",
    body: JSON.stringify(body),
  });
}

export async function deleteProduct(id: string) {
  return apiFetch<{ success: boolean }>(`/products/${id}`, {
    method: "DELETE",
  });
}
```

### 3.2 All API types live in /types/api.ts
Types must match Postman response schemas exactly.

```ts
// types/api.ts

export interface ApiResponse<T> {
  data: T;
  message: string;
  success: boolean;
  pagination?: Pagination;
}

export interface Pagination {
  page: number;
  limit: number;
  total: number;
  totalPages: number;
}

// Add your domain types here — name them exactly as Postman labels them
export interface Product {
  id: string;
  name: string;
  price: number;
  image: string;
  category: string;
  createdAt: string;
}

export type ProductsResponse = ApiResponse<Product[]>;
export type ProductQueryParams = {
  page?: number;
  limit?: number;
  search?: string;
  category?: string;
};

export type CreateProductPayload = Omit<Product, "id" | "createdAt">;
```

### 3.3 Environment variables
```env
NEXT_PUBLIC_API_BASE_URL=https://your-api-domain.com/api/v1
```
Never hardcode URLs. Always use process.env.

### 3.4 Auth tokens (if needed)
```ts
// For authenticated requests, read token from cookies (SSR-safe)
import { cookies } from "next/headers";

export async function getWithAuth<T>(endpoint: string): Promise<T> {
  const token = cookies().get("token")?.value;
  return apiFetch<T>(endpoint, {
    headers: { Authorization: `Bearer ${token}` },
    cache: "no-store",
  });
}
```

