## 4. UI / DESIGN RULES

### 4.1 shadcn/ui is the primary component library
Install and use shadcn components — never rebuild what shadcn already provides.

```tsx
// ✅ Use shadcn
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Skeleton } from "@/components/ui/skeleton";
import { Dialog, DialogContent, DialogHeader, DialogTitle } from "@/components/ui/dialog";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/ui/table";
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from "@/components/ui/select";
```

### 4.2 Tailwind CSS rules
- Mobile-first always: `class="w-full md:w-1/2 lg:w-1/3"`
- No inline styles — Tailwind classes only
- Custom tokens go in tailwind.config.ts, not inline
- Use cn() from /lib/utils for conditional classes

```tsx
import { cn } from "@/lib/utils";

<div className={cn(
  "rounded-lg border p-4",
  isActive && "border-primary bg-primary/5",
  className
)} />
```

### 4.3 Responsive breakpoints (use all three)
```tsx
// Grid example
<div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">

// Text sizing
<h1 className="text-2xl md:text-3xl lg:text-4xl font-bold">

// Padding/spacing
<section className="py-8 md:py-12 lg:py-16 px-4 md:px-8 lg:px-16">

// Flex layout
<div className="flex flex-col md:flex-row gap-4">
```

### 4.4 Images from /public/ui/ (mandatory rules)
```tsx
import Image from "next/image";

// ✅ CORRECT — always use next/image
<Image
  src="/ui/hero-banner.png"
  alt="Descriptive alt text"
  width={1200}
  height={600}
  priority          // add for above-the-fold images
  className="w-full h-auto object-cover rounded-lg"
/>

// For background-style or unknown dimensions
<div className="relative w-full aspect-video">
  <Image
    src="/ui/product-bg.jpg"
    alt="Product background"
    fill
    className="object-cover"
  />
</div>

// ❌ WRONG — never use <img> tag
<img src="/ui/hero.png" />
```

### 4.5 Loading states
Every async component must have a skeleton.

```tsx
// app/products/loading.tsx
import { Skeleton } from "@/components/ui/skeleton";

export default function Loading() {
  return (
    <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 p-4">
      {Array.from({ length: 6 }).map((_, i) => (
        <Skeleton key={i} className="h-64 w-full rounded-lg" />
      ))}
    </div>
  );
}
```

---

## 5. TOAST & SWEETALERT2 RULES

### 5.1 Use /lib/notify.ts — never import toast or Swal directly in components

```ts
// lib/notify.ts
import toast from "react-hot-toast";
import Swal from "sweetalert2";

// ── Toast helpers (for non-destructive feedback) ──

export const notify = {
  success: (message: string) =>
    toast.success(message, { duration: 3000 }),

  error: (message: string) =>
    toast.error(message, { duration: 4000 }),

  info: (message: string) =>
    toast(message, { icon: "ℹ️", duration: 3000 }),

  loading: (message: string) =>
    toast.loading(message),

  dismiss: (id?: string) =>
    toast.dismiss(id),

  promise: <T>(
    promise: Promise<T>,
    messages: { loading: string; success: string; error: string }
  ) => toast.promise(promise, messages),
};

// ── SweetAlert2 helpers (for destructive / confirmation actions) ──

export const alert = {
  confirm: async (options?: {
    title?: string;
    text?: string;
    confirmText?: string;
    cancelText?: string;
  }) => {
    const result = await Swal.fire({
      title: options?.title ?? "Are you sure?",
      text: options?.text ?? "This action cannot be undone.",
      icon: "warning",
      showCancelButton: true,
      confirmButtonText: options?.confirmText ?? "Yes, proceed",
      cancelButtonText: options?.cancelText ?? "Cancel",
      confirmButtonColor: "#ef4444",
      cancelButtonColor: "#6b7280",
      reverseButtons: true,
    });
    return result.isConfirmed;
  },

  success: (title: string, text?: string) =>
    Swal.fire({ title, text, icon: "success", confirmButtonColor: "#10b981" }),

  error: (title: string, text?: string) =>
    Swal.fire({ title, text, icon: "error", confirmButtonColor: "#ef4444" }),

  info: (title: string, text?: string) =>
    Swal.fire({ title, text, icon: "info", confirmButtonColor: "#3b82f6" }),
};
```

### 5.2 When to use which

| Situation | Use |
|-----------|-----|
| Form submitted successfully | `notify.success()` |
| API error or validation fail | `notify.error()` |
| Loading state for a promise | `notify.promise()` |
| Delete / remove an item | `alert.confirm()` → then notify |
| Logout confirmation | `alert.confirm()` |
| Session expired | `alert.error()` |
| Destructive bulk action | `alert.confirm()` |

### 5.3 Usage pattern in client components

```tsx
"use client";
import { notify, alert } from "@/lib/notify";
import { deleteProduct } from "@/lib/api";

async function handleDelete(id: string) {
  const confirmed = await alert.confirm({
    title: "Delete product?",
    text: "This will permanently remove the product.",
    confirmText: "Delete",
  });

  if (!confirmed) return;

  try {
    await notify.promise(deleteProduct(id), {
      loading: "Deleting product...",
      success: "Product deleted successfully",
      error: "Failed to delete product",
    });
  } catch {
    // error is already shown by notify.promise
  }
}
```

### 5.4 Setup in root layout

```tsx
// app/layout.tsx
import { Toaster } from "react-hot-toast";

export default function RootLayout({ children }) {
  return (
    <html lang="en">
      <body>
        {children}
        <Toaster
          position="top-right"
          toastOptions={{
            className: "font-sans text-sm",
            success: { iconTheme: { primary: "#10b981", secondary: "#fff" } },
            error: { iconTheme: { primary: "#ef4444", secondary: "#fff" } },
          }}
        />
      </body>
    </html>
  );
}
```

---

## 6. TYPESCRIPT RULES

- Strict mode enabled in tsconfig.json (`"strict": true`)
- No `any` — use `unknown` and narrow it, or create a proper type
- No `@ts-ignore` — fix the type issue instead
- All function parameters and return types must be explicit
- API response data must be typed (from /types/api.ts)
- Props interfaces must be defined for every component

```tsx
// ✅ CORRECT
interface ProductCardProps {
  product: Product;
  onDelete?: (id: string) => void;
  className?: string;
}

export function ProductCard({ product, onDelete, className }: ProductCardProps) {
  ...
}

// ❌ WRONG
export function ProductCard({ product, onDelete, className }: any) { ... }
```

---

## 7. "USE CLIENT" RULES — when to add it

Only add `"use client"` when the component needs:
- useState or useReducer
- useEffect (not for data fetching)
- Event handlers (onClick, onChange, onSubmit)
- Browser APIs (window, localStorage, document)
- Third-party client-only libraries (SweetAlert2, charts, maps)

```tsx
// ✅ Client component — needs state and event handler
"use client";
import { useState } from "react";

export function SearchBar({ onSearch }: { onSearch: (q: string) => void }) {
  const [query, setQuery] = useState("");
  return (
    <input
      value={query}
      onChange={(e) => setQuery(e.target.value)}
      onKeyDown={(e) => e.key === "Enter" && onSearch(query)}
    />
  );
}
```

The pattern: keep pages as server components, extract interactive bits into small client components.

---

## 8. ERROR HANDLING

```tsx
// app/products/error.tsx — required in every route
"use client";
import { Button } from "@/components/ui/button";

export default function Error({
  error,
  reset,
}: {
  error: Error;
  reset: () => void;
}) {
  return (
    <div className="flex flex-col items-center justify-center min-h-[400px] gap-4">
      <h2 className="text-xl font-semibold">Something went wrong</h2>
      <p className="text-muted-foreground text-sm">{error.message}</p>
      <Button onClick={reset}>Try again</Button>
    </div>
  );
}
```

---

## 9. NAMING CONVENTIONS

| Item | Convention | Example |
|------|------------|---------|
| Files / folders | kebab-case | `product-card.tsx` |
| Components | PascalCase | `ProductCard` |
| Functions | camelCase | `getProducts()` |
| Types / Interfaces | PascalCase | `ProductCardProps` |
| Constants | UPPER_SNAKE | `API_BASE_URL` |
| CSS classes | Tailwind only | `"flex gap-4 p-4"` |
| Route folders | kebab-case | `/app/product-detail/` |

---

## 10. FORBIDDEN PATTERNS

- ❌ `<img>` — use `<Image>` from next/image
- ❌ `useEffect` for data fetching — use server components
- ❌ `fetch()` inside components — use lib/api.ts
- ❌ `import toast from 'react-hot-toast'` in components — use lib/notify.ts
- ❌ `import Swal from 'sweetalert2'` in components — use lib/notify.ts
- ❌ Inline styles — use Tailwind classes
- ❌ `any` type — use proper typing
- ❌ Missing alt on `<Image>` — always required
- ❌ Missing generateMetadata on pages — always required
- ❌ Hardcoded API URLs — use env variables
- ❌ Custom HTML instead of shadcn components when shadcn has it

---

## QUICK REFERENCE

```
New page?          → Server component + generateMetadata() + loading.tsx + error.tsx
New API call?      → Add to lib/api.ts + add type to types/api.ts
New image?         → Put in public/ui/ + use next/image
Delete action?     → alert.confirm() first, then notify.promise()
Client feature?    → Extract to small "use client" component
New component?     → Check shadcn first before building custom
```
